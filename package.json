{
  "name": "webapp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "vite --port=3001",
    "build": "vite build",
    "serve": "vite preview",
    "start": "vite",
    "test": "vitest",
    "e2e": "playwright test",
    "e2e:debug": "playwright test --headed --debug",
    "e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.1",
    "fts5-sql-bundle": "^1.0.2",
    "google-palette": "^1.1.1",
    "jotai": "^2.20.1",
    "papaparse": "^5.5.4",
    "rc-resize-observer": "^1.4.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "use-navigation-api": "^0.5.0"
  },
  "prettier": {
    "printWidth": 100,
    "bracketSameLine": true
  },
  "lint-staged": {
    "*.{js,css,md}": "prettier --write"
  }
